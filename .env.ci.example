# .env.ci.example
#
# Reference values the GitHub Actions workflow `.github/workflows/test.yml`
# reads from repository secrets. Copy into a local `.env.local` for the
# same set of variables during local development. None of the values
# below are real — they are placeholders that document the shape.
#
# Required for Phase 1 e2e tests:
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
# Read-only Strapi API token; can read Product + Category.
STRAPI_API_TOKEN=replace-me
CLERK_SECRET_KEY=replace-me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-me
E2E_CLERK_USER_EMAIL=replace-me
E2E_CLERK_USER_PASSWORD=replace-me
# Used by scripts that need admin access (e.g. issuing a write token).
STRAPI_ADMIN_EMAIL=admin@aurastore.dev
STRAPI_ADMIN_PASSWORD=replace-me

# Required for Phase 2 e2e tests (added per docs/workspace/phase_2/
# AuraStore_Phase2_Implementation_Plan.md Step 7.1):
# Strapi write token; Read + Write + Update on api::order.order only.
STRAPI_API_TOKEN_WRITE=replace-me
# Razorpay Test Mode keys (rzp_test_*).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_replace-me
RAZORPAY_KEY_SECRET=replace-me
# HMAC-SHA256 signing secret used by the webhook handler. Generate via
# Razorpay dashboard Settings > Webhooks > Create new webhook > "Generate".
RAZORPAY_WEBHOOK_SECRET=replace-me

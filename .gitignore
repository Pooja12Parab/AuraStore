# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright auth state
playwright/.auth/

/docs/superpowers/
.superpowers/
playwright-report/*
test-results/*

# clerk configuration (can include secrets)
/.clerk/

# session scratch (Stage 6+)
# - shell-arg-bomb filenames (created by `bash` redirection mistakes)
/-*
# - local scratch dir convention
/tmp/
# - agent scratch (Kilo)
/.kilo/

# Strapi admin credentials + manual seed payloads (session scratch, never commit)
/login.json
/test-prod.json
/update-prod.json
/scratch-*.json
/seed-*.json
/test-*.json

